# =============================================================================
# THE POOLE MANIFOLD: TEST 2 - THE EVENT HORIZON (DENSITY LIMIT)
# Objective: Prove singularities do not exist. Massive density causes localized
# hardware rejection, creating a topologically severed Event Horizon.
# =============================================================================

import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
import time
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"[*] Compiling Event Horizon Substrate on: {device}")

class SingularityManifold:
    def __init__(self, size=64):
        self.size = size
        self.center = size // 2
        self.state = torch.zeros((1, 1, size, size, size), device=device, dtype=torch.int8)
        
        # Inject an "Impossible" Mass (The Singularity)
        # A perfectly solid 12x12x12 block of active voxels. 
        # Interior voxels will have a neighbor sum of 26 (Massively exceeding the 7.0 limit)
        s = 6 
        self.state[..., self.center-s:self.center+s, 
                        self.center-s:self.center+s, 
                        self.center-s:self.center+s] = 1
        
        self.B_LOW, self.B_HIGH = 5.0, 7.0 
        self.S_LOW, self.S_HIGH = 5.0, 9.0
        self.PRIMES = torch.tensor([2, 3, 5, 7], device=device).float()
        
        self.kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
        self.kernel[0, 0, 1, 1, 1] = 0.0
        
        # Telemetry
        self.generation = 0
        self.core_density_history = []
        self.shell_mass_history = []

    def _prime_resonance_operator(self, potential):
        resonance = torch.zeros_like(potential)
        for p in self.PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        return resonance

    def autonomous_clock_cycle(self):
        with torch.no_grad():
            current_float = self.state.float() 
            padded = F.pad(current_float, (1, 1, 1, 1, 1, 1), mode='constant', value=0)
            
            potential = F.conv3d(padded, self.kernel, padding=0)
            resonance = self._prime_resonance_operator(potential)
            total_phi = potential + resonance
            
            birth = (self.state == 0) & (total_phi >= self.B_LOW) & (total_phi <= self.B_HIGH)
            survive = (self.state == 1) & (total_phi >= self.S_LOW) & (total_phi <= self.S_HIGH)
            
            self.state = (birth | survive).to(torch.int8)
            self.generation += 1
            
            # --- MEASURE THE CORE VS THE SHELL ---
            # The core is the inner 6x6x6 space where the singularity was injected
            core_mask = self.state[..., self.center-3:self.center+3, 
                                        self.center-3:self.center+3, 
                                        self.center-3:self.center+3]
            
            # The shell is the surrounding computational space
            total_mass = self.state.float().sum().item()
            core_mass = core_mask.float().sum().item()
            
            self.core_density_history.append(core_mass)
            self.shell_mass_history.append(total_mass - core_mass)

# =============================================================================
# EXECUTION COMMAND
# =============================================================================
manifold = SingularityManifold(size=64) 
MAX_STEPS = 50 

print("[+] IMPOSSIBLE MASS INJECTED (SUM = 26). COMPUTATIONAL LIMIT EXCEEDED.")
print("[+] OBSERVING TOPOLOGICAL COLLAPSE...")

for t in range(MAX_STEPS):
    manifold.autonomous_clock_cycle()

# =============================================================================
# GRAPHING THE EVENT HORIZON
# =============================================================================
plt.figure(figsize=(10, 6), facecolor='#111111')
ax = plt.gca()
ax.set_facecolor('#111111')

plt.plot(manifold.core_density_history, color='#ff4444', linewidth=3, label='Core Mass (The Singularity)')
plt.plot(manifold.shell_mass_history, color='#00ffcc', linewidth=3, label='Shell Mass (The Event Horizon)')

plt.title("Test 2: Topological Hardware Crash (Black Hole Dynamics)", color='white', pad=15)
plt.xlabel("Time (Discrete Generations)", color='white')
plt.ylabel("Active Voxels (Kinetic Mass)", color='white')
ax.tick_params(colors='white')
ax.grid(color='gray', alpha=0.2)
plt.legend(facecolor='#222222', labelcolor='white')

plt.tight_layout()
plt.show()
