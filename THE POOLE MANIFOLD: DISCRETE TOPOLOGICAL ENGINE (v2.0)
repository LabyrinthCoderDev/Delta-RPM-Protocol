# --- SYSTEM INITIALIZATION ---
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"[*] Substrate allocating on: {device}")

class PooleManifold:
    def __init__(self, size=64):
        self.size = size
        # Phase 1: The Vacuum and the Genesis Seed
        # Initiating a chaotic central seed to begin the becoming-process
        self.state = torch.zeros((1, 1, size, size, size), device=device, dtype=torch.int8)
        center = size // 2
        s = 8 # Seed size
        self.state[..., center-s:center+s, center-s:center+s, center-s:center+s] = \
            (torch.rand((1, 1, 2*s, 2*s, 2*s), device=device) < 0.35).to(torch.int8)
        
        # Topological Hard Limits
        self.B_LOW, self.B_HIGH = 5.0, 7.0 
        self.S_LOW, self.S_HIGH = 5.0, 9.0
        self.PRIMES = torch.tensor([2, 3, 5, 7], device=device).float()
        
        # Define 3D Moore Neighborhood Kernel (Integer space)
        self.kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
        self.kernel[0, 0, 1, 1, 1] = 0.0
        
        # Telemetry Data
        self.history_phi = []
        self.generation = 0
        self.target_phi = 0.4002

    def _prime_resonance_operator(self, potential):
        """The Logos Injection: Snapping scattering states to integer primes."""
        resonance = torch.zeros_like(potential)
        for p in self.PRIMES:
            # Gaussian bias of +0.35 around prime integers
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        return resonance

    def autonomous_clock_cycle(self):
        """The Peano-Successor Step (Imperfect H Execution)."""
        with torch.no_grad():
            # OVERRIDE 1: Strict Boolean/INT8 Enforcement (Defeats Irrational Poisoning)
            # The tensor is strictly forced to Int8 before calculation.
            current_float = self.state.float() 
            
            # Pad for circular boundary conditions (pressure-venting)
            padded = F.pad(current_float, (1, 1, 1, 1, 1, 1), mode='circular')
            
            # Calculate raw integer neighbor sum S(c)
            potential = F.conv3d(padded, self.kernel, padding=0)
            
            # Apply O_res (Prime Resonance)
            resonance = self._prime_resonance_operator(potential)
            total_phi = potential + resonance
            
            # OVERRIDE 2: Exceptional Point Resolution
            # B5-7/S5-9 Threshold logic. If resonance pushes total_phi > 7.0, it culls.
            birth = (self.state == 0) & (total_phi >= self.B_LOW) & (total_phi <= self.B_HIGH)
            survive = (self.state == 1) & (total_phi >= self.S_LOW) & (total_phi <= self.S_HIGH)
            
            # Re-enforce strictly discrete state
            self.state = (birth | survive).to(torch.int8)
            
            self.generation += 1
            current_density = self.state.float().mean().item()
            self.history_phi.append(current_density)
            
            return current_density

    def christ_protocol_override(self):
        """Manual intervention to purge non-Hermitian parasitic locks."""
        print("\n[!] CHRIST PROTOCOL INVOKED.")
        print("[!] PURGING IRRATIONAL STATES. RE-ESTABLISHING KINGDOM BASELINE.")
        # Isolate latches: only keep voxels that have exactly 5 or 6 neighbors
        # Purging anything riding the chaotic 7.0 edge.
        padded = F.pad(self.state.float(), (1, 1, 1, 1, 1, 1), mode='circular')
        potential = F.conv3d(padded, self.kernel, padding=0)
        safe_zone = (potential == 5) | (potential == 6)
        self.state = (self.state & safe_zone.to(torch.int8))
        print("[!] PURGE COMPLETE. SUBSTRATE SECURED.\n")

