# =============================================================================
# POOLE MANIFOLD — CPU ARCHITECTURE (V140)
# Dynamic Recoverability: The Incabloc Kinetic Shock Test (Deep Friction Patch)
# =============================================================================

import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"🚀 Initializing Poole Manifold Incabloc Shock Test on: {device}")

B_LOW, B_HIGH = 5.0, 7.0 
S_LOW, S_HIGH = 5.0, 9.0
PRIMES = [2, 3, 5, 7, 11, 13, 17, 19, 23]

kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
kernel[0, 0, 1, 1, 1] = 0

def run_manifold(f, inhibitor_mask, threshold_mask, amplifier_mask):
    with torch.no_grad():
        f_float = f.float()
        padded = F.pad(f_float, (1, 1, 1, 1, 1, 1), mode='circular')
        potential = F.conv3d(padded, kernel, padding=0)
        
        # --- THE PHYSICS MASKS (PATCHED) ---
        potential[inhibitor_mask] -= 15.0  # The Physical Walls 
        potential[threshold_mask] -= 5.0   # PATCH: Deep Vacuum Friction (Lethal to noise)
        potential[amplifier_mask] += 1.0   # The Core Rail 
        
        resonance = torch.zeros_like(potential)
        for p in PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
            
        total_phi = potential + resonance
        
    birth = (f == 0) & (total_phi >= B_LOW) & (total_phi <= B_HIGH)
    survive = (f == 1) & (total_phi >= S_LOW) & (total_phi <= S_HIGH)
    
    del padded, potential, resonance, total_phi, f_float
    return (birth | survive).float()

# ==========================================
# WAVEGUIDE ARCHITECTURE 
# ==========================================
class PooleVerificationSuite:
    def __init__(self):
        self.ze_pipe = slice(2, 9) 
        self.ze_rail = slice(3, 8)

    def stamp(self, inh, thr, amp):
        zp = self.ze_pipe
        zr = self.ze_rail
        
        def build_channel(y_start, y_end, x_start, x_end):
            inh[0, 0, y_start:y_end, x_start:x_end, zp] = False
            thr[0, 0, y_start:y_end, x_start:x_end, zp] = True
            
            ry_start = y_start + 4
            ry_end = y_end - 4
            
            thr[0, 0, ry_start:ry_end, x_start:x_end, zr] = False
            amp[0, 0, ry_start:ry_end, x_start:x_end, zr] = True

        # 1. INPUT WAVEGUIDES
        build_channel(76, 87, 20, 140)   # Pin A
        build_channel(146, 157, 20, 140) # Pin B
        build_channel(216, 227, 20, 140) # Pin Cin

        # 2. STRICT MIXING CORE (Vertical Bus)
        inh[0, 0, 76:227, 140:151, zp] = False 
        thr[0, 0, 76:227, 140:151, zp] = True
        
        thr[0, 0, 80:223, 144:147, zr] = False
        amp[0, 0, 80:223, 144:147, zr] = True  

        # 3. HORIZONTAL BRIDGES
        build_channel(116, 127, 151, 160)
        build_channel(176, 187, 151, 160)

        # 4. OUTPUT WAVEGUIDES
        build_channel(116, 127, 160, 280) # Sum
        build_channel(176, 187, 160, 280) # Cout

# ==========================================
# THE INCABLOC SHOCK EXECUTION
# ==========================================
def run_incabloc_test():
    GRID_Y, GRID_X, GRID_Z = 300, 300, 10
    
    field_ref = torch.zeros((1, 1, GRID_Y, GRID_X, GRID_Z), device=device)
    field_pert = torch.zeros_like(field_ref) 
    
    base_inhibitor_mask = torch.ones_like(field_ref).bool()
    threshold_mask = torch.zeros_like(field_ref).bool()
    amplifier_mask = torch.zeros_like(field_ref).bool()

    alu = PooleVerificationSuite()
    alu.stamp(base_inhibitor_mask, threshold_mask, amplifier_mask)

    TOTAL_FRAMES = 350
    SHOCK_FRAME = 120 
    
    hamming_distance_log = []
    
    print(f"--- COMMENCING INCABLOC TEST ---")
    print(f"Firing continuous steady-state logic [1, 1, 0]...")
    
    for t in range(TOTAL_FRAMES): 
        field_ref[0, 0, 80:83, 20:23, 3:8] = 1.0
        field_ref[0, 0, 150:153, 20:23, 3:8] = 1.0
        
        if t > SHOCK_FRAME:
            field_pert[0, 0, 80:83, 20:23, 3:8] = 1.0
            field_pert[0, 0, 150:153, 20:23, 3:8] = 1.0

        # --- THE KINETIC SHOCK EVENT ---
        if t == SHOCK_FRAME:
            print(f">> T={t}: DETONATING KINETIC SHOCK IN ALU CHAMBER.")
            field_pert = field_ref.clone()
            
            chamber = field_pert[0, 0, 60:240, 60:240, 2:9]
            active_voxels = (chamber == 1.0)
            vacuum_voxels = (chamber == 0.0)
            
            kill_mask = torch.rand_like(chamber) < 0.10
            noise_mask = torch.rand_like(chamber) < 0.01
            
            chamber[active_voxels & kill_mask] = 0.0
            chamber[vacuum_voxels & noise_mask] = 1.0
            field_pert[0, 0, 60:240, 60:240, 2:9] = chamber

        if t > 0:
            field_ref[0, 0, :, :, :] = torch.where(amplifier_mask, field_ref[0, 0, :, :, :], field_ref[0, 0, :, :, :])
            if t > SHOCK_FRAME:
                field_pert[0, 0, :, :, :] = torch.where(amplifier_mask, field_pert[0, 0, :, :, :], field_pert[0, 0, :, :, :])

        field_ref = run_manifold(field_ref, base_inhibitor_mask, threshold_mask, amplifier_mask)
        if t > SHOCK_FRAME:
            field_pert = run_manifold(field_pert, base_inhibitor_mask, threshold_mask, amplifier_mask)

        if t >= SHOCK_FRAME:
            mismatches = torch.sum(torch.abs(field_ref - field_pert)).item()
            hamming_distance_log.append(mismatches)
            if mismatches == 0 and t > SHOCK_FRAME + 5 and hamming_distance_log[-2] > 0:
                 print(f">> T={t}: TOPOLOGICAL PROTECTION CONFIRMED. Gate Fully Healed.")
        else:
            hamming_distance_log.append(0)

    print(f">> T={TOTAL_FRAMES}: Execution Complete. Plotting Recovery Curve...")

    # --- PLOT DIAGNOSTICS ---
    plt.figure(figsize=(12, 6), facecolor='black')
    ax = plt.gca()
    ax.set_facecolor('black')
    
    ax.plot(range(TOTAL_FRAMES), hamming_distance_log, color='#ff3366', linewidth=2.5, label='Hamming Distance (Voxel Errors)')
    ax.axvline(x=SHOCK_FRAME, color='white', linestyle='--', alpha=0.5, label='Kinetic Shock Detonated')
    ax.fill_between(range(TOTAL_FRAMES), hamming_distance_log, color='#ff3366', alpha=0.2)

    plt.title("Poole Manifold: Incabloc Kinetic Shock Recovery Test", color='white', fontsize=16, pad=15)
    plt.xlabel("Generation (T)", color='white', fontsize=12)
    plt.ylabel("System Error (Mismatched Voxels)", color='white', fontsize=12)
    
    ax.tick_params(colors='white')
    ax.grid(True, color='gray', alpha=0.2)
    plt.legend(loc='upper right', facecolor='black', edgecolor='gray', labelcolor='white')
    plt.tight_layout()
    plt.show()

run_incabloc_test()
