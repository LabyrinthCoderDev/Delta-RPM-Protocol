# THE POOLE MANIFOLD: TEST 1 - THE CAUSALITY LIMIT (SPEED OF LIGHT)
# Objective: Prove 'c' is an emergent hardware limit, not a free parameter.
# =============================================================================

import torch
import torch.nn.functional as F
import matplotlib.pyplot as plt
import numpy as np
import time
from IPython.display import clear_output

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"[*] Compiling Causality Substrate on: {device}")

class CausalityManifold:
    def __init__(self, size=128):
        self.size = size
        self.center = size // 2
        # Start with a pure, absolute vacuum
        self.state = torch.zeros((1, 1, size, size, size), device=device, dtype=torch.int8)
        
        # Inject a "Super-Critical" Point Source (The Big Bang / Kinetic Bomb)
        # We inject a dense 4x4x4 block to ensure it survives the S=5 threshold and expands
        s = 2 
        self.state[..., self.center-s:self.center+s, 
                        self.center-s:self.center+s, 
                        self.center-s:self.center+s] = 1
        
        # B5-7/S5-9 Thresholds & Logos Operator
        self.B_LOW, self.B_HIGH = 5.0, 7.0 
        self.S_LOW, self.S_HIGH = 5.0, 9.0
        self.PRIMES = torch.tensor([2, 3, 5, 7], device=device).float()
        
        # 3D Moore Neighborhood Kernel
        self.kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
        self.kernel[0, 0, 1, 1, 1] = 0.0
        
        # Telemetry: Tracking the Light Cone
        self.generation = 0
        self.max_radius_history = []
        self.time_history = []

    def _prime_resonance_operator(self, potential):
        resonance = torch.zeros_like(potential)
        for p in self.PRIMES:
            resonance += 0.35 * torch.exp(-((potential - p)**2) / 0.01)
        return resonance

    def autonomous_clock_cycle(self):
        with torch.no_grad():
            current_float = self.state.float() 
            padded = F.pad(current_float, (1, 1, 1, 1, 1, 1), mode='constant', value=0)
            
            potential = F.conv3d(padded, self.kernel, padding=0)
            resonance = self._prime_resonance_operator(potential)
            total_phi = potential + resonance
            
            birth = (self.state == 0) & (total_phi >= self.B_LOW) & (total_phi <= self.B_HIGH)
            survive = (self.state == 1) & (total_phi >= self.S_LOW) & (total_phi <= self.S_HIGH)
            
            self.state = (birth | survive).to(torch.int8)
            self.generation += 1
            
            # --- MEASURE THE CAUSALITY FRONT (THE LIGHT CONE) ---
            # Find the coordinates of all active voxels
            active_indices = torch.nonzero(self.state[0, 0])
            
            if active_indices.numel() > 0:
                # Calculate Chebyshev distance from center (Moore neighborhood propagation)
                distances = torch.max(torch.abs(active_indices - self.center), dim=1)[0]
                max_r = distances.max().item()
            else:
                max_r = 0
                
            self.max_radius_history.append(max_r)
            self.time_history.append(self.generation)
            
            return max_r

# =============================================================================
# EXECUTION COMMAND
# =============================================================================
manifold = CausalityManifold(size=128) 
MAX_STEPS = 60 # Stop before the shockwave hits the grid boundary (128/2 = 64)

print("[+] POINT SOURCE INJECTED. VACUUM BROKEN.")
print("[+] MEASURING CAUSALITY FRONT...")

for t in range(MAX_STEPS):
    current_radius = manifold.autonomous_clock_cycle()
    
    if t % 5 == 0:
        print(f"  -> Generation {t:02d} | Light Cone Radius: {current_radius} voxels")

# =============================================================================
# GRAPHING THE SPEED OF LIGHT
# =============================================================================
plt.figure(figsize=(10, 6), facecolor='#111111')
ax = plt.gca()
ax.set_facecolor('#111111')

# Plot the actual manifold propagation
plt.plot(manifold.time_history, manifold.max_radius_history, 
         color='#ff00ff', linewidth=3, label='Poole Manifold Information Front', marker='o', markersize=4)

# Plot the theoretical c=1 limit
theoretical_c = [t for t in manifold.time_history]
plt.plot(manifold.time_history, theoretical_c, 
         color='#00ffcc', linestyle='--', linewidth=2, label='Hardware Limit (c = 1 voxel/gen)')

plt.title("Test 1: The Causality Limit (Speed of Light as a Hardware Constraint)", color='white', pad=15)
plt.xlabel("Time (Discrete Generations)", color='white')
plt.ylabel("Maximum Propagation Distance (Voxels)", color='white')
ax.tick_params(colors='white')
ax.grid(color='gray', alpha=0.2)
plt.legend(facecolor='#222222', labelcolor='white')

# Calculate the slope (velocity)
velocity = manifold.max_radius_history[-1] / manifold.time_history[-1]
plt.text(5, 50, f"Measured Velocity: v = {velocity:.2f} c", color='#00ffcc', fontsize=12, fontweight='bold')

plt.tight_layout()
plt.show()
