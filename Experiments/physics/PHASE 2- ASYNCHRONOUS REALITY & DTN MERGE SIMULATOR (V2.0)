device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# ─────────────────────────────────────────────
#  THE ASYNCHRONOUS MANIFOLD
# ─────────────────────────────────────────────
class AsynchronousManifold:
    def __init__(self, name, anchor_seed):
        self.name = name
        self.size = anchor_seed.shape[-1]
        self.state = anchor_seed.clone().to(device)
        self.local_clock = 0
        
        self.kernel = torch.ones((1, 1, 3, 3, 3), device=device).float()
        self.kernel[0, 0, 1, 1, 1] = 0.0

    def compute_generation(self, inject_chaos=False):
        """Computes one local tick. Mars and Earth do this independently."""
        with torch.no_grad():
            padded = F.pad(self.state, (1, 1, 1, 1, 1, 1), mode='constant', value=0)
            potential = F.conv3d(padded, self.kernel, padding=0)
            
            # Standard B5-7/S5-9 Logic
            birth = (self.state == 0) & (potential >= 5.0) & (potential <= 7.0)
            survive = (self.state == 1) & (potential >= 5.0) & (potential <= 9.0)
            
            self.state = (birth | survive).float()
            
            if inject_chaos:
                # The Yasser Anomaly: Injecting impossible density (e.g., 26.0)
                c = self.size // 2
                self.state[..., c-1:c+2, c-1:c+2, c-1:c+2] = 1.0 # Solid 3x3x3 block
                
            self.local_clock += 1
            max_density = potential.max().item() if not inject_chaos else 26.0
            return max_density

# ─────────────────────────────────────────────
#  THE Z3 SENTINEL (EARTH NODE)
# ─────────────────────────────────────────────
class Phase2Sentinel:
    def __init__(self):
        self.solver = z3.Solver()
        self.z_density = z3.Real('density')
        # Invariant 1: Local density must not exceed 7.0 (The Cull)
        self.solver.add(self.z_density <= 7.0)

    def verify_dtn_bundle(self, mars_max_density):
        self.solver.push()
        self.solver.add(self.z_density == mars_max_density)
        is_valid = self.solver.check() == z3.sat
        self.solver.pop()
        return is_valid

# ─────────────────────────────────────────────
#  UI HELPERS
# ─────────────────────────────────────────────
def ts(): return datetime.now().strftime("%H:%M:%S")

def c_print(speaker, msg):
    colors = {
        "ROOKE": "\033[96m", "ALVER": "\033[92m", "ECHO": "\033[93m", 
        "CLAUDE": "\033[95m", "SYS": "\033[90m", "ALERT": "\033[91m", "RESET": "\033[0m"
    }
    col = colors.get(speaker, "\033[0m")
    sys_col = colors["SYS"]
    res = colors["RESET"]
    
    if speaker == "SYS" or speaker == "ALERT":
        print(f"{col}[{ts()}] {msg}{res}")
    else:
        print(f"{sys_col}[{ts()}]{res} {col}[{speaker:<6}]{res} {msg}")

