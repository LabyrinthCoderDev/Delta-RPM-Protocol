# 4. TOPOLOGICAL STRESS TESTING (OMNI-SHOCK)
# ==========================================
def apply_omni_shock(tensor):
    """Applies Starvation, Over-saturation, and Thermal Noise simultaneously."""
    print("-> Applying Concurrent Omni-Shock (Void + Supernova + Thermal Noise)...")
    shocked = tensor.clone()
    
    # 1. The Void
    shocked[0, 0, 10:42, 10:42, 10:42] = 0.0
    # 2. The Supernova
    shocked[0, 0, -26:-10, -26:-10, -26:-10] = 1.0
    # 3. Thermal Noise (5% global inversion)
    noise_mask = (torch.rand_like(shocked) < 0.05)
    shocked = torch.logical_xor(shocked.bool(), noise_mask).float()
    
    return shocked

