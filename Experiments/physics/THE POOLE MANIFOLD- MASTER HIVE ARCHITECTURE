def relu(x: jnp.ndarray) -> jnp.ndarray:
    return jnp.maximum(0.0, x)

def boolean_combiner(features: jnp.ndarray, subformula_indices: List[Tuple[str, List[int]]]) -> jnp.ndarray:
    out = []
    for op, dims in subformula_indices:
        if op == 'pos':          
            val = features[..., dims[0]]
        elif op == 'neg':        
            val = relu(1.0 - features[..., dims[0]])
        elif op == 'and':        
            val = relu(features[..., dims[0]] + features[..., dims[1]] - 1.0)
        else:
            raise ValueError(f"Unknown operation: {op}")
        out.append(val[..., None])
    return jnp.concatenate(out, axis=-1)

def monomial_gadget(features: jnp.ndarray, monomial_list: List[List[int]], marked_dim: int, degree: int) -> jnp.ndarray:
    N = features.shape[0]
    scale = 1.0 / N
    monomials = []
    
    for monomial_dims in monomial_list:
        val = features[:, monomial_dims[0]][:, None]
        val = jnp.mean(val, axis=0)
        
        for d in monomial_dims[1:]:
            factor = features[:, d][:, None]
            gated = relu(val - (1.0 - features[:, marked_dim][:, None]))
            val = gated * factor
            val = jnp.mean(val, axis=0)
            
        monomials.append(val * (scale ** (len(monomial_dims) - 1)))
        
    return jnp.concatenate(monomials, axis=-1)

def peano_evaluator(monomials: jnp.ndarray, peano_terms: List[Dict], r1: float, r2: float) -> jnp.ndarray:
    term_vals = []
    for term in peano_terms:
        coeffs = jnp.array(term['coeffs'])
        poly = jnp.sum(coeffs * monomials, axis=-1) 
        t = relu(poly - term['b'] * r1) 
        yt = relu(t - relu(t - r2)) 
        zt = relu(r2 - yt) 
        term_vals.append(zt)
    return term_vals[0] # Returning first term evaluation for single-inequality constraints

class PolynomialPeanoGlobalLayer:
    def __init__(self, subformula_indices: List[Tuple[str, List[int]]],
                 monomial_list: List[List[int]], 
                 peano_terms: List[Dict], marked_color_dim: int = 0):
        self.subformula_indices = subformula_indices
        self.monomial_list = monomial_list
        self.peano_terms = peano_terms
        self.marked_dim = marked_color_dim

    def __call__(self, node_features: jnp.ndarray) -> jnp.ndarray:
        bool_feats = boolean_combiner(node_features, self.subformula_indices)
        feats = jnp.concatenate([node_features, bool_feats], axis=-1)
        
        degree = max([len(m) for m in self.monomial_list]) if self.monomial_list else 1
        monoms = monomial_gadget(feats, self.monomial_list, self.marked_dim, degree=degree)
        
        N = node_features.shape[0]
        r1 = 1.0 / (N ** degree)
        r2 = 1.0 / (N ** len(self.peano_terms[0]['coeffs'])) 
        
        # Calculate the global certainty score (Scalar)
        certainty = peano_evaluator(monoms, self.peano_terms, r1, r2)
        
        # THE PATCH: Broadcast the single scalar score across all N nodes
        certainty_expanded = jnp.broadcast_to(certainty, (N, 1))
        
        # Safely concatenate arrays of identical dimension depth
        return jnp.concatenate([feats, certainty_expanded], axis=-1)
