# PART 2: THE SYMPY HIVE COMPILER
# -----------------------------------------------------------------------------

class HiveCompiler:
    def __init__(self):
        pass
        
    def extract_variable_index(self, symbol_str):
        match = re.search(r'\d+', str(symbol_str))
        if match:
            return int(match.group())
        raise ValueError(f"[ERROR] Cannot map variable '{symbol_str}'.")

    def compile_invariant(self, rule_name, equation_string):
        print(f"\n[COMPILER] Target Lock: {rule_name}")
        
        if '<=' in equation_string:
            lhs_str, rhs_str = equation_string.split('<=')
            expr = sp.sympify(lhs_str) - sp.sympify(rhs_str)
        elif '>=' in equation_string:
            lhs_str, rhs_str = equation_string.split('>=')
            expr = sp.sympify(rhs_str) - sp.sympify(lhs_str)
        else:
            expr = sp.sympify(equation_string)

        expr = sp.expand(expr)
        terms = expr.as_coefficients_dict()

        monomial_list = []
        coeffs = []
        b_constant = 0.0
        unique_vars = set()

        for term, coeff in terms.items():
            if term == 1:
                b_constant = -float(coeff) 
                continue

            factors = term.as_ordered_factors()
            monomial_indices = []
            
            for f in factors:
                if f.is_Symbol:
                    idx = self.extract_variable_index(f)
                    monomial_indices.append(idx)
                    unique_vars.add(idx)
                elif f.is_Pow and f.base.is_Symbol:
                    idx = self.extract_variable_index(f.base)
                    monomial_indices.extend([idx] * int(f.exp))
                    unique_vars.add(idx)

            monomial_list.append(monomial_indices)
            coeffs.append(float(coeff))

        peano_term = {'coeffs': coeffs, 'b': b_constant}
        subformula_indices = [('pos', [v]) for v in sorted(list(unique_vars))]
        
        print(f"  -> Translated to {len(monomial_list)} monomials.")
        
        return {
            "subformula_indices": subformula_indices,
            "monomial_list": monomial_list,
            "peano_terms": [peano_term]
        }

