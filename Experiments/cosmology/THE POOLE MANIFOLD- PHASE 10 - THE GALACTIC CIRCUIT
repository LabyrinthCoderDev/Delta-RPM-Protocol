# --- VELOCITY FUNCTIONS ---
# 1. The Broken Continuous Model (Newtonian / Keplerian)
# Expectation: Velocity drops off exponentially at the edges.
def v_newtonian(r):
    return np.sqrt(G_M / r)

# 2. The Poole Manifold Model (OTG Phase-Locking)
# Reality: The Phi flux creates an algebraic baseline that prevents speed decay.
def v_otg(r):
    # Base gravity + the computational routing drag from the Succession Flux
    return np.sqrt((G_M / r) + (PHI_FLUX * (C_LIMIT**2) * (1 - np.exp(-r/10))))

# Calculate the actual velocities for our stars
